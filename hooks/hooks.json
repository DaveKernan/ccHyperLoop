{
  "description": "ccHyperLoop plugin hooks — orchestrator Stop hook and async version check",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/check-update.sh",
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/orchestrator-stop-hook.sh"
          }
        ]
      }
    ]
  }
}
